<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <title>Calculadora de Energia</title>
  <style>
    body { font-family: Arial, sans-serif; margin: 30px; }
    label { display: block; margin-top: 10px; }
    input { margin-top: 5px; padding: 5px; width: 200px; }
    button { margin-top: 15px; padding: 10px 20px; }
    #resultado { margin-top: 20px; font-weight: bold; }
  </style>
</head>
<body>
  <h1>Calculadora de Consumo de Energia</h1>
  
  <label for="potencia">Potência do aparelho (W):</label>
  <input type="number" id="potencia" placeholder="Ex: 1000">

  <label for="tempo">Tempo de uso (horas):</label>
  <input type="number" id="tempo" placeholder="Ex: 5">

  <label for="custo">Custo do kWh (R$):</label>
  <input type="number" id="custo" placeholder="Ex: 0.80" step="0.01">

  <button onclick="calcular()">Calcular</button>

  <div id="resultado"></div>

  <script>
    function calcular() {
      const potencia = parseFloat(document.getElementById('potencia').value);
      const tempo = parseFloat(document.getElementById('tempo').value);
      const custo = parseFloat(document.getElementById('custo').value);

      if (isNaN(potencia) || isNaN(tempo) || isNaN(custo)) {
        document.getElementById('resultado').innerText = "Por favor, preencha todos os campos corretamente.";
        return;
      }

      // Consumo em kWh = (Potência em W * Tempo em horas) / 1000
      const consumo = (potencia * tempo) / 1000;
      const valor = consumo * custo;

      document.getElementById('resultado').innerText = 
        `Consumo: ${consumo.toFixed(2)} kWh\nCusto: R$ ${valor.toFixed(2)}`;
    }
  </script>
</body>
</html>

